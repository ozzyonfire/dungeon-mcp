{
  "name": "dungeon-mcp",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "mcp"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:server": "bun --filter backend run dev",
    "test:backend": "cd backend && bun run test",
    "typecheck:backend": "cd backend && bun run typecheck",
    "dev:frontend": "cd frontend && bun run dev",
    "build:frontend": "cd frontend && bun run build",
    "preview:frontend": "cd frontend && bun run preview",
    "dev:mcp": "cd mcp && bun run dev",
    "typecheck:mcp": "cd mcp && bun run typecheck"
  }
}
